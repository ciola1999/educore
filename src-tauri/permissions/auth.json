{
  "identifier": "default",
  "description": "Permit all local application commands",
  "commands": {
    "allow": [
      "authenticate_with_biometric",
      "set_password",
      "verify_password",
      "verify_local_desktop_login",
      "get_sync_config",
      "set_sync_config",
      "get_runtime_bootstrap_config",
      "probe_runtime_bootstrap_health",
      "ensure_runtime_bootstrap_ready"
    ]
  }
}
